# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# Local secrets & data
.env
.env.*
!.env.example
/data/
**/data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Node (extensions later)
node_modules/
dist/
*.log

