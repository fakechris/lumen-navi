{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumen Navi",
  "version": "0.1.0",
  "identifier": "com.lumennavi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lumen Navi",
        "width": 1080,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/henry.w@example.net",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {}
}
